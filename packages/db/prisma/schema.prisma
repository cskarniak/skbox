generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Device {
  id           String   @id @default(cuid())
  name         String
  protocol     String
  type         String
  status       String   @default("offline")
  room         String?
  parentObject String?
  state        String   @default("{}")
  address      String?
  ieeeAddress  String?  @unique
  rfxcomId     String?  @unique
  vendor       String?
  model        String?
  mqttTopic    String?
  visible      Boolean  @default(true)
  active       Boolean  @default(true)
  trackHistory Boolean  @default(false)
  displayPreferences String @default("[]")
  historyFieldConfig String @default("[]")
  batteryChangePendingUntil DateTime?
  lastSeen     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events DeviceEvent[]
  themes Theme[]

  @@index([protocol])
  @@index([room])
  @@index([parentObject])
  @@index([ieeeAddress])
  @@index([rfxcomId])
}

model DeviceEvent {
  id        String   @id @default(cuid())
  deviceId  String
  event     String
  data      String   @default("{}")
  timestamp DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
}

model ServiceEvent {
  id        String   @id @default(cuid())
  service   String
  event     String
  detail    String?
  createdAt DateTime @default(now())

  @@index([service, createdAt])
}

model Scenario {
  id         String    @id @default(cuid())
  name       String
  enabled    Boolean   @default(true)
  trigger    String
  conditions String    @default("[]")
  actions    String    @default("[]")
  lastRun    DateTime?
  runCount   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Room {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ParentObject {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Theme {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  devices Device[]
}

model Camera {
  id        String   @id @default(cuid())
  name      String
  room      String?
  // URL RTSP complète, identifiants inclus — jamais renvoyée au frontend, seule
  // l'API (via go2rtc) y accède pour enregistrer/mettre à jour le flux.
  rtspUrl   String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model HistoryTemplate {
  id        String   @id @default(cuid())
  name      String
  panels    String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
