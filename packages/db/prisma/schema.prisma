generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Device {
  id           String   @id @default(cuid())
  name         String
  protocol     String
  type         String
  status       String   @default("offline")
  room         String?
  parentObject String?
  state        String   @default("{}")
  address      String?
  ieeeAddress  String?  @unique
  rfxcomId     String?  @unique
  vendor       String?
  model        String?
  mqttTopic    String?
  visible      Boolean  @default(true)
  active       Boolean  @default(true)
  trackHistory Boolean  @default(false)
  temperatureOffset Float @default(0)
  humidityOffset    Float @default(0)
  displayPreferences String @default("[]")
  historyFieldConfig String @default("[]")
  batteryChangePendingUntil DateTime?
  lastSeen     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events DeviceEvent[]
  themes Theme[]

  @@index([protocol])
  @@index([room])
  @@index([parentObject])
  @@index([ieeeAddress])
  @@index([rfxcomId])
}

model DeviceEvent {
  id        String   @id @default(cuid())
  deviceId  String
  event     String
  data      String   @default("{}")
  timestamp DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
}

model ServiceEvent {
  id        String   @id @default(cuid())
  service   String
  event     String
  detail    String?
  createdAt DateTime @default(now())

  @@index([service, createdAt])
}

model Scenario {
  id         String    @id @default(cuid())
  name       String
  enabled    Boolean   @default(true)
  // "automation" (par défaut) ou "alarm" — un scénario "alarm" est journalisé dans
  // AlarmEvent (déclenchement/résolution/acquittement) en plus d'exécuter ses actions.
  category   String    @default("automation")
  severity   String?
  // Nom du ScenarioGroup pour l'affichage (ex: "Ventilation sous-sol") — les scénarios
  // partageant le même group sont repliés ensemble dans la liste. Référence par nom
  // (pas de FK) pour rester simple : la table ScenarioGroup n'est qu'un registre des
  // noms valides, gérée depuis les paramètres.
  group      String?
  trigger    String
  conditions String    @default("[]")
  // "AND" (défaut) ou "OR" — combine les éléments de `conditions` entre eux.
  conditionsOperator String @default("AND")
  actions    String    @default("[]")
  lastRun    DateTime?
  runCount   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  alarmEvents AlarmEvent[]
}

model ScenarioGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlarmEvent {
  id             String    @id @default(cuid())
  scenarioId     String
  triggeredAt    DateTime  @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  triggerValue   String    @default("{}")

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId, resolvedAt])
}

// Un profil de simulation de présence : une liste de lampes qui s'allument/s'éteignent
// selon un horaire (fixe ou solaire) avec des bascules aléatoires entre les deux, pour
// simuler une présence à domicile. Le plan du jour est calculé une fois par jour et
// journalisé dans PresenceSimulationRun/Event pour permettre de vérifier son exécution.
model PresenceSimulation {
  id                 String   @id @default(cuid())
  name               String
  enabled            Boolean  @default(true)
  lightDeviceIds     String   @default("[]") // JSON string[] de Device.id
  onTime             String // JSON TimeOrSolar (fixe HH:MM ou lever/coucher ± décalage)
  offTime            String // JSON TimeOrSolar
  onRandomOffsetMin  Int      @default(0) // minutes
  onRandomOffsetMax  Int      @default(0)
  offRandomOffsetMin Int      @default(0)
  offRandomOffsetMax Int      @default(0)
  toggleCountMin     Int      @default(0)
  toggleCountMax     Int      @default(0)
  toggleDurationMin  Int      @default(1) // minutes
  toggleDurationMax  Int      @default(30)
  toggleWindowStart  String   @default("22:00") // HH:MM, début de la fenêtre où les bascules peuvent survenir (le reste de la soirée reste stable)
  toggleWindowEnd    String   @default("23:00") // HH:MM, fin de la fenêtre de bascules
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  runs PresenceSimulationRun[]

  @@index([enabled])
}

// Le plan résolu (horaires + événements) d'un profil pour une date donnée, et le
// résultat de la vérification quotidienne de ce plan.
model PresenceSimulationRun {
  id           String    @id @default(cuid())
  profileId    String
  date         String // "YYYY-MM-DD"
  plannedOnAt  DateTime
  plannedOffAt DateTime
  verifiedAt   DateTime?
  verifiedOk   Boolean?
  createdAt    DateTime  @default(now())

  profile PresenceSimulation        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  events  PresenceSimulationEvent[]

  @@unique([profileId, date])
  @@index([profileId, date])
}

// Un événement planifié (allumage initial, extinction finale, ou bascule intermédiaire)
// avec le résultat de son exécution (publication MQTT).
model PresenceSimulationEvent {
  id          String    @id @default(cuid())
  runId       String
  kind        String // "on" | "off" | "toggle_on" | "toggle_off"
  action      String // "ON" | "OFF"
  scheduledAt DateTime
  executedAt  DateTime?
  success     Boolean? // null = pas encore dû
  error       String?
  createdAt   DateTime  @default(now())

  run PresenceSimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, scheduledAt])
  @@index([scheduledAt])
}

model Room {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ParentObject {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Theme {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  devices Device[]
}

model Camera {
  id        String   @id @default(cuid())
  name      String
  room      String?
  // Connexion RTSP décomposée — reconstruite en `rtsp://[user[:pass]@]host[:port][path]`
  // par l'API pour parler à go2rtc.
  host      String
  port      Int      @default(554)
  path      String   @default("")
  username  String?
  password  String?
  // Port ONVIF (PTZ + réglages image), null si la caméra n'expose pas ONVIF.
  onvifPort Int?     @default(8000)
  // API utilisée pour les réglages image (luminosité/contraste/saturation/netteté) : "onvif" ou "reolink".
  // Le PTZ passe toujours par ONVIF. Certaines caméras (ex. Reolink) répondent avec succès à
  // SetImagingSettings en ONVIF sans jamais appliquer le changement — on bascule alors sur leur
  // API CGI propriétaire, qui fonctionne réellement.
  imagingApi String  @default("onvif")
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imagingProfiles CameraImagingProfile[]
}

// Un jeu nommé de réglages image (luminosité/contraste/saturation/netteté) qu'on peut
// réappliquer d'un clic à la caméra, sans avoir à retrouver les valeurs manuellement.
model CameraImagingProfile {
  id         String   @id @default(cuid())
  cameraId   String
  name       String
  brightness Int?
  contrast   Int?
  saturation Int?
  sharpness  Int?
  createdAt  DateTime @default(now())

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([cameraId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model HistoryTemplate {
  id        String   @id @default(cuid())
  name      String
  panels    String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
